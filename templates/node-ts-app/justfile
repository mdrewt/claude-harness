set windows-shell := ["cmd.exe", "/c"]
# Delegates to npm scripts (single source of truth for commands).

setup:
    npm run setup

lint:
    npm run lint

typecheck:
    npm run typecheck

test:
    npm run test

eval:
    npm run eval

security:
    npm run security

mutate:
    npx stryker run

changelog:
    git cliff -o CHANGELOG.md

ci:
    npm run ci
