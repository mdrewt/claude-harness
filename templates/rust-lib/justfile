set windows-shell := ["cmd.exe", "/c"]
setup:
    cargo fetch

lint:
    cargo clippy --all-targets -- -D warnings && cargo fmt --check

typecheck:
    cargo check --all-targets

test:
    cargo test

eval:
    cargo test --test architecture

# check-secrets is the local gate; SCA (cargo audit) is advisory locally and the
# authoritative gate in CI (see .github/workflows/ci.yml).
security:
    node scripts/check-secrets.mjs .
    cargo audit || echo "cargo audit: advisory locally; CI gates SCA"

mutate:
    cargo mutants

changelog:
    git cliff -o CHANGELOG.md

ci: lint typecheck test eval security
